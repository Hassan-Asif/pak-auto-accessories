rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /products/{productId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if request.resource.data.status == 'Pending Confirmation'
        && request.resource.data.paymentMethod in ['COD', 'Easypaisa', 'JazzCash', 'Bank Transfer'];
      allow read: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow create: if true;
      allow read, update: if isAdmin() || (signedIn() && request.auth.uid == customerId);
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if signedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
